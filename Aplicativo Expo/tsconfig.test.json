{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["jest", "node"],
    "noEmit": true
  },
  "include": [
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "__mocks__/**/*.ts",
    "jest.setup.ts",
    "nativewind-env.d.ts",
    "src/data/**/*.ts",
    "src/utils/**/*.ts",
    "src/context/**/*.tsx",
    "src/constants/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
