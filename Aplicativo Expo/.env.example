# Remote SQLite catalogs (Azure Blob SAS)
EXPO_PUBLIC_REMOTE_VIDEOS_DB_URL=
EXPO_PUBLIC_REMOTE_CHANNELS_DB_URL=
EXPO_PUBLIC_REMOTE_VIDEOS_DB_FILENAME=videos.sqlite
EXPO_PUBLIC_REMOTE_CHANNELS_DB_FILENAME=channels.sqlite

# Local sync paths & freshness
EXPO_PUBLIC_DB_DIR_NAME=sqlite-remote
EXPO_PUBLIC_DB_META_DIR_NAME=db-meta
EXPO_PUBLIC_SYNC_STALE_MS=3600000

# AsyncStorage keys
EXPO_PUBLIC_HISTORY_STORAGE_KEY=hak.watch.history
EXPO_PUBLIC_RATINGS_STORAGE_KEY=hak.video.ratings

# Feed / ranking / limits
EXPO_PUBLIC_MAX_HISTORY=500
EXPO_PUBLIC_FEED_MIN_DAY_GAP=3
EXPO_PUBLIC_MUSIC_RECENT_COOLDOWN=10
EXPO_PUBLIC_CHANNEL_NO_VIEWS_WEIGHT=0.15
EXPO_PUBLIC_HOME_CHANNEL_LIMIT=12
EXPO_PUBLIC_RELATED_VIDEOS_LIMIT=10

# Search
EXPO_PUBLIC_SEARCH_DEBOUNCE_MS=250

# Shorts playback
EXPO_PUBLIC_SHORTS_PRELOAD_AHEAD=2
EXPO_PUBLIC_SHORTS_PRELOAD_BEHIND=1
EXPO_PUBLIC_SHORTS_VISIBLE_PCT=55
EXPO_PUBLIC_SHORTS_MIN_VIEW_MS=80

# Layout
EXPO_PUBLIC_TAB_BAR_HEIGHT=49

# Theme
EXPO_PUBLIC_THEME_BG=#212121
EXPO_PUBLIC_THEME_SURFACE=#0f0f0f
EXPO_PUBLIC_THEME_CHIP=rgba(255,255,255,0.1)
EXPO_PUBLIC_THEME_MUTED=#aaaaaa
EXPO_PUBLIC_THEME_RED=#FF0000
EXPO_PUBLIC_THEME_WHITE=#ffffff
EXPO_PUBLIC_THEME_BORDER=#303030
